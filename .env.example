# Backend Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fairpadel

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=24h

# Frontend URL
FRONTEND_URL=http://localhost:5173

# App
PORT=3000
NODE_ENV=development

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Resend (Email Service)
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=FairPadel <noreply@fairpadel.com>

# Frontend Environment Variables (Vite)
VITE_API_URL=http://localhost:3000/api

# Bancard VPOS 2.0 (Suscripciones)
# Obtener claves en: https://comercios.bancard.com.py
BANCARD_PUBLIC_KEY=your-public-key-here
BANCARD_PRIVATE_KEY=your-private-key-here
# Ambiente: 'staging' o 'production'
BANCARD_ENV=staging

# Feature Flags
# Activar nuevo algoritmo de descanso: true o false
FEATURE_DESCANSO_V2=true

# ID de torneo específico para probar el nuevo algoritmo (opcional)
# Si se especifica, solo ese torneo usará el nuevo algoritmo
# Ejemplo: FEATURE_DESCANSO_V2_TORNEO_ID=abc-123-def
FEATURE_DESCANSO_V2_TORNEO_ID=

# WhatsApp Business API (Meta)
# Feature flag principal - si es false, el módulo opera en modo silencioso
WHATSAPP_ENABLED=false

# Credenciales de Meta (requeridas si WHATSAPP_ENABLED=true)
# Obtener en: https://developers.facebook.com/apps
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# Versión de la API de Meta (opcional, default: v17.0)
WHATSAPP_API_VERSION=v17.0

# Webhook verification (para validar webhooks de Meta)
WHATSAPP_VERIFY_TOKEN=your-verify-token-here

# Webhook secret (para verificar firma de webhooks, opcional)
WHATSAPP_WEBHOOK_SECRET=
