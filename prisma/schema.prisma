// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════

enum Gender {
  MASCULINO
  FEMENINO
}

enum UserStatus {
  NO_VERIFICADO
  ACTIVO
  INACTIVO
  SUSPENDIDO
}

enum TournamentStatus {
  BORRADOR
  PENDIENTE_APROBACION
  PUBLICADO
  EN_CURSO
  FINALIZADO
  RECHAZADO
  CANCELADO
}

// Modalidades ahora son configurables, no solo un enum
// Cada modalidad define las reglas del torneo
model ModalidadConfig {
  id          String   @id @default(uuid())
  nombre      String   @unique  // Ej: "Clásico", "Mixto", "Suma", "Americano"
  descripcion String   @db.Text
  activa      Boolean  @default(true)
  
  // Reglas de la modalidad (JSON flexible)
  // Ejemplo: { 
  //   tipoEmparejamiento: "PAREJA_FIJA", // o "ROTATIVO", "INDIVIDUAL"
  //   generoRequerido: "MIXTO", // o "MASCULINO", "FEMENINO", "CUALQUIERA"
  //   sistemaPuntos: "TRADICIONAL", // o "SUMA", "SETS"
  //   formatoBracket: "ELIMINACION_DIRECTA", // o "GRUPOS", "LIGA"
  //   setsPorPartido: 3,
  //   puntosPorVictoria: 100,
  //   puntosPorDerrota: 50,
  //   requierePareja: true,
  //   permiteIndividual: false
  // }
  reglas      Json     @default("{}")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  torneos     TournamentModalidad[]

  @@map("modalidades_config")
}

enum CategoriaEstado {
  INSCRIPCIONES_ABIERTAS
  INSCRIPCIONES_CERRADAS
  FIXTURE_BORRADOR
  SORTEO_REALIZADO
  EN_CURSO
  FINALIZADA
}

enum InscripcionEstado {
