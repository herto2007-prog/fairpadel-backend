generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════

enum UserStatus {
  NO_VERIFICADO
  ACTIVO
  INACTIVO
  SUSPENDIDO
}

enum RoleName {
  jugador
  organizador
  admin
}

enum TournamentStatus {
  BORRADOR
  PENDIENTE_APROBACION
  PUBLICADO
  EN_CURSO
  FINALIZADO
  CANCELADO
}

enum TournamentCategoryStatus {
  INSCRIPCIONES_ABIERTAS
  INSCRIPCIONES_CERRADAS
  FIXTURE_BORRADOR
  SORTEO_REALIZADO
  EN_CURSO
  FINALIZADA
}

enum CategoriaTipo {
  MASCULINO
  FEMENINO
  MIXTO
}

enum InscripcionEstado {
  PENDIENTE_CONFIRMACION
  CONFIRMADA
  RECHAZADA
  CANCELADA
}

enum ModoPagoInscripcion {
  COMPLETO
  INDIVIDUAL
}

// NUEVOS ENUMS PARA FIXTURE
enum TipoRanking {
  GLOBAL
  PAIS
  REGION
  CIUDAD
  CATEGORIA
  TORNEO
}

enum RondaTipo {
  ACOMODACION_1
  ACOMODACION_2
  OCTAVOS
  CUARTOS
  SEMIS
  FINAL
  TERCER_PUESTO
}

enum MatchStatus {
  PROGRAMADO
  EN_JUEGO
  FINALIZADO
  WO
  SUSPENDIDO
  CANCELADO
}

enum FixtureVersionStatus {
  BORRADOR
  PUBLICADO
  ARCHIVADO
}

// ═══════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String     @map("password_hash")
  nombre        String
  apellido      String
  documento     String     @unique
  telefono      String
  status        UserStatus @default(NO_VERIFICADO)
  
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  
  roles         UserRole[]
  tournaments   Tournament[] @relation("OrganizadorTournaments")
  
  // Inscripciones
  inscripcionesJugador1 Inscripcion[] @relation("InscripcionJugador1")
  inscripcionesJugador2 Inscripcion[] @relation("InscripcionJugador2")
  
  // Rankings
  rankings              Ranking[]
  
  @@map("users")
}

model Role {
  id        String     @id @default(uuid())
  name      RoleName   @unique
  createdAt DateTime   @default(now()) @map("created_at")
  
  users     UserRole[]
  
  @@map("roles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@unique([userId, roleId])
  @@map("user_roles")
}

model Tournament {
  id                String           @id @default(uuid())
  nombre            String
  descripcion       String?
  slug              String           @unique
  estado            TournamentStatus @default(BORRADOR)
  
  // Fechas del torneo
  fechaInicio       DateTime         @map("fecha_inicio")
  fechaFin          DateTime         @map("fecha_fin")
  fechaInicioInscripcion DateTime?   @map("fecha_inicio_inscripcion")
  fechaFinInscripcion    DateTime?   @map("fecha_fin_inscripcion")
  
  // Configuración
  maxParejas        Int?             @map("max_parejas")
  minParejas        Int?             @map("min_parejas")
  puntosRanking     Int?             @map("puntos_ranking")
  premio            String?
  flyerUrl          String?          @map("flyer_url")
  
  // Relaciones
  organizadorId     String           @map("organizador_id")
  organizador       User             @relation("OrganizadorTournaments", fields: [organizadorId], references: [id])
  
  categories        TournamentCategory[]
  inscripciones     Inscripcion[]
  fixtureVersions   FixtureVersion[]
  matches           Match[]
  
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  
  @@map("tournaments")
}

model Category {
  id          String        @id @default(uuid())
  nombre      String        @unique
  tipo        CategoriaTipo
  orden       Int           // 1=1ra, 2=2da, 3=3ra... 8=8va
  descripcion String?
  
  createdAt   DateTime      @default(now()) @map("created_at")
  
  tournaments TournamentCategory[]
  inscripciones Inscripcion[]
  fixtureVersions FixtureVersion[]
  matches     Match[]
  
  @@map("categories")
}

model TournamentCategory {
  id            String                   @id @default(uuid())
  tournamentId  String                   @map("tournament_id")
  categoryId    String                   @map("category_id")
  
  tournament    Tournament               @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category      Category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  
  inscripcionAbierta Boolean            @default(true) @map("inscripcion_abierta")
  estado        TournamentCategoryStatus @default(INSCRIPCIONES_ABIERTAS)
  
  cupoMaximo    Int?                     @map("cupo_maximo")
  
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")
  
  @@unique([tournamentId, categoryId])
  @@map("tournament_categories")
}

model Inscripcion {
  id                String                @id @default(uuid())
  tournamentId      String                @map("tournament_id")
  categoryId        String                @map("category_id")
  
  // Jugadores
  jugador1Id        String                @map("jugador1_id")
  jugador2Id        String?               @map("jugador2_id")
  jugador2Documento String?               @map("jugador2_documento")
  jugador2Email     String?               @map("jugador2_email")
  
  estado            InscripcionEstado     @default(PENDIENTE_CONFIRMACION)
  modoPago          ModoPagoInscripcion?  @map("modo_pago")
  
  notas             String?
  
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  
  // Relaciones
  tournament        Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category          Category              @relation(fields: [categoryId], references: [id])
  jugador1          User                  @relation("InscripcionJugador1", fields: [jugador1Id], references: [id])
  jugador2          User?                 @relation("InscripcionJugador2", fields: [jugador2Id], references: [id])
  
  // Relación con matches (como pareja)
  matchesPareja1    Match[]               @relation("MatchPareja1")
  matchesPareja2    Match[]               @relation("MatchPareja2")
  matchesGanados    Match[]               @relation("MatchGanador")
  matchesPerdidos   Match[]               @relation("MatchPerdedor")
  
  @@map("inscripciones")
}

// ═══════════════════════════════════════════════════════
// FIXTURE VERSIONADO (SEMANA 3)
// ═══════════════════════════════════════════════════════

model FixtureVersion {
  id                String                @id @default(uuid())
  tournamentId      String                @map("tournament_id")
  categoryId        String                @map("category_id")
  version           Int                   @default(1)
  
  estado            FixtureVersionStatus  @default(BORRADOR)
  
  // Definición del fixture como JSON
  definicion        Json                  @map("definicion")
  
  totalPartidos     Int                   @default(0) @map("total_partidos")
  
  publicadoAt       DateTime?             @map("publicado_at")
  archivadoAt       DateTime?             @map("archivado_at")
  
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  
  // Relaciones
  tournament        Tournament            @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category          Category              @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  matches           Match[]
  
  @@unique([tournamentId, categoryId, version])
  @@map("fixture_versions")
}

model Match {
  id                    String          @id @default(uuid())
  tournamentId          String          @map("tournament_id")
  categoryId            String          @map("category_id")
  fixtureVersionId      String          @map("fixture_version_id")
  
  // Ronda y posición
  ronda                 RondaTipo
  numeroRonda           Int             @map("numero_ronda")
  ordenEnRonda          Int             @default(0) @map("orden_en_ronda")
  
  // Parejas (referencia a inscripciones)
  pareja1Id             String?         @map("pareja1_id")
  pareja2Id             String?         @map("pareja2_id")
  
  // Información de la pareja (para mostrar sin join)
  pareja1Nombre         String?         @map("pareja1_nombre")
  pareja2Nombre         String?         @map("pareja2_nombre")
  
  // Cancha y horario
  canchaId              String?         @map("cancha_id")
  canchaNombre          String?         @map("cancha_nombre")
  fechaProgramada       DateTime?       @map("fecha_programada")
  horaProgramada        String?         @map("hora_programada")
  horaFinEstimada       String?         @map("hora_fin_estimada")
  
  // Estado
  estado                MatchStatus     @default(PROGRAMADO)
  
  // Resultados - Sets (máximo 3 sets)
  set1Pareja1           Int?            @map("set1_pareja1")
  set1Pareja2           Int?            @map("set1_pareja2")
  set2Pareja1           Int?            @map("set2_pareja1")
  set2Pareja2           Int?            @map("set2_pareja2")
  set3Pareja1           Int?            @map("set3_pareja1")
  set3Pareja2           Int?            @map("set3_pareja2")
  
  // Ganador
  parejaGanadoraId      String?         @map("pareja_ganadora_id")
  parejaPerdedoraId     String?         @map("pareja_perdedora_id")
  
  // Enlaces para bracket
  partidoSiguienteId    String?         @map("partido_siguiente_id")
  posicionEnSiguiente   String?         @map("posicion_en_siguiente") // "P1" o "P2"
  
  // Metadata
  esBye                 Boolean         @default(false) @map("es_bye")
  notas                 String?
  
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  
  // Relaciones
  tournament            Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category              Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  fixtureVersion        FixtureVersion  @relation(fields: [fixtureVersionId], references: [id], onDelete: Cascade)
  
  pareja1               Inscripcion?    @relation("MatchPareja1", fields: [pareja1Id], references: [id])
  pareja2               Inscripcion?    @relation("MatchPareja2", fields: [pareja2Id], references: [id])
  parejaGanadora        Inscripcion?    @relation("MatchGanador", fields: [parejaGanadoraId], references: [id])
  parejaPerdedora       Inscripcion?    @relation("MatchPerdedor", fields: [parejaPerdedoraId], references: [id])
  partidoSiguiente      Match?          @relation("MatchBracket", fields: [partidoSiguienteId], references: [id])
  partidosAnteriores    Match[]         @relation("MatchBracket")
  
  @@map("matches")
}

// ═══════════════════════════════════════════════════════
// RANKING (SEMANA 4)
// ═══════════════════════════════════════════════════════

model Ranking {
  id                    String       @id @default(uuid())
  jugadorId             String       @map("jugador_id")
  
  tipoRanking           TipoRanking  @map("tipo_ranking")
  alcance               String?      // Ej: "Paraguay", "Asunción", "1ra"
  referenciaAlcance     String?      @map("referencia_alcance") // ID de categoría, ciudad, etc.
  
  // Estadísticas
  puntosTotales         Int          @default(0) @map("puntos_totales")
  torneosJugados        Int          @default(0) @map("torneos_jugados")
  partidosGanados       Int          @default(0) @map("partidos_ganados")
  partidosPerdidos      Int          @default(0) @map("partidos_perdidos")
  
  // Logros
  victorias             Int          @default(0) // 1ros puestos
  finales               Int          @default(0) // 2dos puestos
  semifinales           Int          @default(0) // 3ros-4tos puestos
  mejorPuestoHistorico  Int?         @map("mejor_puesto_historico")
  
  temporada             String?      // Año o identificador de temporada
  ultimaActualizacion   DateTime     @updatedAt @map("ultima_actualizacion")
  
  createdAt             DateTime     @default(now()) @map("created_at")
  
  // Relaciones
  jugador               User         @relation(fields: [jugadorId], references: [id], onDelete: Cascade)
  
  @@unique([jugadorId, tipoRanking, alcance, temporada])
  @@index([tipoRanking, puntosTotales])
  @@index([jugadorId])
  @@map("rankings")
}
