// ═══════════════════════════════════════════════════════
// MÓDULO 1: USUARIOS Y AUTENTICACIÓN
// ═══════════════════════════════════════════════════════

model User {
  id                      String       @id @default(uuid())
  email                   String       @unique
  password                String       @map("password")
  nombre                  String
  apellido                String
  documento               String       @unique
  telefono                String?
  fechaNacimiento         DateTime?    @map("fecha_nacimiento")
  genero                  Gender
  ciudad                  String?
  pais                    String       @default("Paraguay")
  fotoUrl                 String?      @map("foto_url")
  bannerUrl               String?      @map("banner_url")
  bio                     String?      @db.Text
  instagram               String?
  facebook                String?
  estado                  UserStatus   @default(NO_VERIFICADO)
  categoriaActualId       String?      @map("categoria_actual_id")
  esPremium               Boolean      @default(false) @map("es_premium")
  fechaFinPremium         DateTime?    @map("fecha_fin_premium")
  stripeCustomerId        String?      @map("stripe_customer_id")
  stripeSubscriptionId    String?      @map("stripe_subscription_id")
  notificacionesEmail     Boolean      @default(true) @map("notificaciones_email")
  notificacionesSms       Boolean      @default(false) @map("notificaciones_sms")
  notificacionesPush      Boolean      @default(true) @map("notificaciones_push")
  createdAt               DateTime     @default(now()) @map("created_at")
  updatedAt               DateTime     @updatedAt @map("updated_at")

  // Relaciones
  roles                    UserRole[]
  solicitudesOrganizador   SolicitudOrganizador[]
  emailVerifications       EmailVerification[]
  passwordResets           PasswordReset[]
  categoriaActual          Category?                @relation("CategoriaActualUsuarios", fields: [categoriaActualId], references: [id])
  rankings                 Ranking[]
  historialPuntos          HistorialPuntos[]
  historialCategorias      HistorialCategoria[]
  ascensosPendientes       AscensoPendiente[]
  
  // NUEVO: Circuitos
  solicitudesTorneoCircuito  TorneoCircuito[] @relation("SolicitudTorneoCircuito")
  aprobacionesTorneoCircuito TorneoCircuito[] @relation("AprobacionTorneoCircuito")
  clasificadosCircuito       ClasificadoCircuito[]
  
  // NUEVO: Inscripciones directas (reemplaza Pareja)
  inscripcionesJugador1    Inscripcion[] @relation("InscripcionJugador1")
  inscripcionesJugador2    Inscripcion[] @relation("InscripcionJugador2")
  
  // Relaciones sociales
  seguidores               Seguimiento[] @relation("UsuarioSeguido")
  siguiendo                Seguimiento[] @relation("UsuarioSeguidor")
  mensajesEnviados         MensajePrivado[] @relation("MensajeRemitente")
  mensajesRecibidos        MensajePrivado[] @relation("MensajeDestinatario")
  solicitudesJugarEnviadas SolicitudJugar[] @relation("SolicitudRemitente")
  solicitudesJugarRecibidas SolicitudJugar[] @relation("SolicitudDestinatario")
  logros                   UsuarioLogro[]
  bloqueosRealizados       Bloqueo[] @relation("BloqueoBloqueador")
  bloqueosRecibidos        Bloqueo[] @relation("BloqueoBloqueado")
  reportesRealizados       Reporte[] @relation("ReporteReportador")
  reportesRecibidos        Reporte[] @relation("ReporteReportado")
  
  // Fotos y feed
  fotosSubidas             Foto[]
  fotosEtiquetado          FotoJugador[]
  likes                    Like[]
  comentarios              Comentario[]
  albums                   Album[]
  publicacionesFeed        PublicacionFeed[]
  likesPublicaciones       LikePublicacion[]
  comentariosPublicaciones ComentarioPublicacion[]
  
  // Notificaciones
  notificaciones           Notificacion[]
  preferenciasNotificacion PreferenciaNotificacion[]
  smsLogs                  SmsLog[]
  fotosPerfilModeracion    FotoPerfilModeracion[]
  movimientosFinancieros   MovimientoFinanciero[] @relation("MovimientosCreados")
  auspiciosCreados         AuspicianteEspecie[] @relation("AuspiciosCreados")
  
  // Suscripciones
  suscripciones            Suscripcion[]
  cupones                  Cupon[] @relation("CuponesUsuario")
  
  // Torneos
  torneosOrganizados       Tournament[] @relation("OrganizadorTorneos")
  ayudanteEnTorneos        TorneoAyudante[] @relation("AyudanteEnTorneos")
  reportesFotos            ReporteFoto[]
  
  // Instructores
  solicitudesInstructor    SolicitudInstructor[] @relation("InstructorSolicitudes")
  instructorPerfil         Instructor?           @relation("InstructorProfile")
  reservasComoAlumno       ReservaInstructor[] @relation("ReservasComoAlumno")
  pagosInstructor          PagoInstructor[]    @relation("PagosInstructorAlumno")
  
  // Pagos
  pagos                    Pago[] @relation("PagosJugador")
  reservasCancha           ReservaCancha[] @relation("ReservasCanchaUsuario")
  
  // Alertas
  alertasPersonalizadas    AlertaPersonalizada[]
  
  // Reservas como mensualero
  jugadorMensualero        JugadorMensualero[]
  
  // Alquileres
  encargadoAlquileres      AlquilerConfig[]
  responsableMensualeros   GrupoMensualero[]
  
  // Demo / Test
  jugadorDemo              JugadorDemo?

  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  createdAt   DateTime @default(now()) @map("created_at")

  users UserRole[]

  @@map("roles")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model SolicitudOrganizador {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  organizacion String?
  telefono     String
  ciudad       String
  experiencia  String
  motivacion   String
  estado       SolicitudEstado @default(PENDIENTE)
  respuesta    String?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("solicitudes_organizador")
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}
// ... (continuación del schema)

// ═══════════════════════════════════════════════════════
// MÓDULO 2: CATEGORÍAS Y SEDES
// ═══════════════════════════════════════════════════════

model Category {
  id        String   @id @default(uuid())
  nombre    String   @unique
  tipo      Gender
  orden     Int
  createdAt DateTime @default(now()) @map("created_at")

  torneos           TournamentCategory[]
  inscripciones     Inscripcion[]
  partidos          Match[]
  historialPuntos   HistorialPuntos[]
  usuariosActuales  User[]              @relation("CategoriaActualUsuarios")
  reglasOrigen      ReglaAscenso[]      @relation("CategoriaOrigen")
  reglasDestino     ReglaAscenso[]      @relation("CategoriaDestino")
  ascensosPendientesActual AscensoPendiente[] @relation("CategoriaActualAscensos")
  ascensosPendientesNueva  AscensoPendiente[] @relation("AscensoPendienteNueva")

  @@map("categories")
}

// NUEVO SISTEMA DE SEDES Y CANCHAS
model Sede {
  id                String      @id @default(uuid())
  nombre            String
  ciudad            String
  direccion         String?
  mapsUrl           String?     @map("maps_url")
  telefono          String?
  activa            Boolean     @default(true)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  canchas                 SedeCancha[]
  torneoSedes             TorneoSede[]
  torneosPrincipal        Tournament[] @relation("SedePrincipal")
  ubicacionesInstructores InstructorUbicacion[]
  alquilerConfig          AlquilerConfig?
  alquilerPrecios         AlquilerPrecio[]
  alquilerBloqueos        AlquilerBloqueo[]
  gruposMensualeros       GrupoMensualero[]

  @@map("sedes")
}

model SedeCancha {
  id          String    @id @default(uuid())
  sedeId      String    @map("sede_id")
  nombre      String
  tipo        TipoCancha @default(SINTETICO)
  tieneLuz    Boolean   @default(false) @map("tiene_luz")
  cubierta    Boolean   @default(false)
  notas       String?   // Características especiales (techada, gradas, etc.)
  activa      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  sede                    Sede           @relation(fields: [sedeId], references: [id], onDelete: Cascade)
  torneoCanchas           TorneoCancha[]
  reservas                ReservaCancha[] @relation("ReservasCanchas")
  partidos                Match[]
  alquilerDisponibilidades AlquilerDisponibilidad[]
  alquilerBloqueos        AlquilerBloqueo[]
  gruposMensualeros       GrupoMensualero[]

  @@map("sede_canchas")
}

// ═══════════════════════════════════════════════════════
// MÓDULO TORNEOS (MODIFICADO)
// ═══════════════════════════════════════════════════════

model TorneoSede {
  id            String    @id @default(uuid())
  tournamentId  String    @map("tournament_id")
  sedeId        String    @map("sede_id")
  orden         Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")

  tournament    Tournament    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  sede          Sede          @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, sedeId])
  @@map("torneo_sedes")
}

model TorneoCancha {
  id            String    @id @default(uuid())
  tournamentId  String    @map("tournament_id")
  sedeCanchaId  String    @map("sede_cancha_id")
  orden         Int       @default(0)
  activa        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")

  tournament    Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  sedeCancha    SedeCancha         @relation(fields: [sedeCanchaId], references: [id], onDelete: Cascade)
  horarios      TorneoCanchaHorario[]
  partidos      Match[]
  slots         TorneoSlot[]

  @@unique([tournamentId, sedeCanchaId])
  @@map("torneo_canchas")
}

model TorneoCanchaHorario {
  id              String    @id @default(uuid())
  torneoCanchaId  String    @map("torneo_cancha_id")
  diaSemana       Int       @map("dia_semana") // 0=Domingo, 6=Sábado
  horaInicio      String    @map("hora_inicio") // "08:00"
  horaFin         String    @map("hora_fin")    // "22:00"
  activo          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")

  torneoCancha TorneoCancha @relation(fields: [torneoCanchaId], references: [id], onDelete: Cascade)

  @@unique([torneoCanchaId, diaSemana, horaInicio])
  @@map("torneo_cancha_horarios")
}

// NUEVO: Disponibilidad específica por fecha del torneo (para sorteo de slots)
model TorneoDisponibilidadDia {
  id            String   @id @default(uuid())
  tournamentId  String   @map("tournament_id")
  fecha         DateTime @db.Timestamptz(3) // Timestamp con timezone para Paraguay UTC-3
  horaInicio    String   @map("hora_inicio") // "18:00"
  horaFin       String   @map("hora_fin")    // "23:00"
  minutosSlot   Int      @default(90) @map("minutos_slot") // Duración de cada partido
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  slots         TorneoSlot[]

  @@unique([tournamentId, fecha])
  @@map("torneo_disponibilidad_dias")
}

// NUEVO: Slots generados para cada día/cancha (la grilla)
model TorneoSlot {
  id                String   @id @default(uuid())
  disponibilidadId  String   @map("disponibilidad_id")
  torneoCanchaId    String   @map("torneo_cancha_id")
  horaInicio        String   @map("hora_inicio") // "18:00"
  horaFin           String   @map("hora_fin")    // "19:30"
  estado            String   @default("LIBRE") // LIBRE, OCUPADO, BLOQUEADO
  fase              String?  @map("fase")       // ZONA, SEMIFINAL, FINAL, etc.
  matchId           String?  @unique @map("match_id")   // Si está ocupado, qué partido (único para 1:1)
  createdAt         DateTime @default(now()) @map("created_at")

  disponibilidad  TorneoDisponibilidadDia @relation(fields: [disponibilidadId], references: [id], onDelete: Cascade)
  torneoCancha    TorneoCancha            @relation(fields: [torneoCanchaId], references: [id], onDelete: Cascade)
  match           Match?                  @relation("SlotPartido", fields: [matchId], references: [id])

  @@unique([disponibilidadId, torneoCanchaId, horaInicio])
  @@map("torneo_slots")
}

model TorneoPelotasRonda {
  id            String    @id @default(uuid())
  tournamentId  String    @map("tournament_id")
  ronda         String    // "ACOMODACION_1", "OCTAVOS", etc.
  cantidad      Int       // Cantidad de pelotas por partido
  precio        Decimal   @db.Decimal(10, 2)
  createdAt     DateTime  @default(now()) @map("created_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, ronda])
  @@map("torneo_pelotas_rondas")
}

model TorneoAyudante {
  id            String    @id @default(uuid())
  tournamentId  String    @map("tournament_id")
  userId        String    @map("user_id")
  permisos      String[]  // ["RESULTADOS", "INSCRIPCIONES", "FINANZAS"]
  createdAt     DateTime  @default(now()) @map("created_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation("AyudanteEnTorneos", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@map("torneo_ayudantes")
}

model Circuito {
  id                      String          @id @default(uuid())
  nombre                  String          @unique
  descripcion             String?         @db.Text
  slug                    String          @unique
  pais                    String          @default("Paraguay")
  region                  String?
  ciudad                  String
  temporada               String          @default("2026")
  estado                  CircuitoEstado  @default(ACTIVO)
  
  // Fechas del circuito
  fechaInicio             DateTime        @map("fecha_inicio")
  fechaFin                DateTime?       @map("fecha_fin")
  fechaLimiteInscripcion  DateTime?       @map("fecha_limite_inscripcion")
  
  // Configuración visual
  logoUrl                 String?         @map("logo_url")
  bannerUrl               String?         @map("banner_url")
  colorPrimario           String?         @default("#df2531") @map("color_primario")
  
  // Configuración del circuito
  tipoAcumulacion         String          @default("ACUMULATIVO") @map("tipo_acumulacion") // ACUMULATIVO, MEJORES_N
  torneosMinimosContar    Int?            @map("torneos_minimos_contar") // Si es MEJORES_N
  torneosParaClasificar   Int             @default(1) @map("torneos_para_clasificar")
  puntosMinimosClasificar Int?            @map("puntos_minimos_clasificar")
  multiplicadorGlobal     Float           @default(1.0) @map("multiplicador_global")
  
  // Configuración de final
  tieneFinal              Boolean         @default(false) @map("tiene_final")
  torneoFinalId           String?         @map("torneo_final_id") @unique
  
  // Orden de visualización
  orden                   Int             @default(0)
  destacado               Boolean         @default(false)
  
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  // Relaciones
  torneos                 TorneoCircuito[]
  torneoFinal             Tournament?     @relation("CircuitoFinal", fields: [torneoFinalId], references: [id])
  clasificados            ClasificadoCircuito[]

  @@map("circuitos")
}

// NUEVO: Relación entre Torneo y Circuito (con metadatos)
model TorneoCircuito {
  id                String    @id @default(uuid())
  circuitoId        String    @map("circuito_id")
  torneoId          String    @map("torneo_id")
  
  // Configuración específica de este torneo en el circuito
  orden             Int       @default(0) // Orden en el circuito (1, 2, 3...)
  puntosValidos     Boolean   @default(true) @map("puntos_validos") // Si cuenta para el circuito
  esFinal           Boolean   @default(false) @map("es_final") // Si es la etapa final
  multiplicador     Float     @default(1.0) // Multiplicador específico para este torneo
  
  // Estado de la solicitud
  estado            String    @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  solicitadoPorId   String    @map("solicitado_por_id")
  aprobadoPorId     String?   @map("aprobado_por_id")
  fechaAprobacion   DateTime? @map("fecha_aprobacion")
  notas             String?   @db.Text
  
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  
  // Relaciones
  circuito          Circuito  @relation(fields: [circuitoId], references: [id], onDelete: Cascade)
  torneo            Tournament @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  solicitadoPor     User      @relation("SolicitudTorneoCircuito", fields: [solicitadoPorId], references: [id])
  aprobadoPor       User?     @relation("AprobacionTorneoCircuito", fields: [aprobadoPorId], references: [id])
  
  @@unique([circuitoId, torneoId])
  @@map("torneo_circuitos")
}

// NUEVO: Clasificados a la final del circuito
model ClasificadoCircuito {
  id                  String    @id @default(uuid())
  circuitoId          String    @map("circuito_id")
  jugadorId           String    @map("jugador_id")
  
  // Datos de clasificación
  puntosAcumulados    Int       @map("puntos_acumulados")
  torneosJugados      Int       @default(0) @map("torneos_jugados")
  posicionClasificacion Int     @map("posicion_clasificacion")
  
  // Estado
  estado              String    @default("CLASIFICADO") // CLASIFICADO, CONFIRMADO, RECHAZADO
  confirmadoEn        DateTime? @map("confirmado_en")
  
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  
  // Relaciones
  circuito            Circuito  @relation(fields: [circuitoId], references: [id], onDelete: Cascade)
  jugador             User      @relation(fields: [jugadorId], references: [id], onDelete: Cascade)
  
  @@unique([circuitoId, jugadorId])
  @@map("clasificados_circuito")
}

model Tournament {
  id                  String            @id @default(uuid())
  nombre              String
  descripcion         String?           @db.Text
  pais                String
  region              String
  ciudad              String
  fechaInicio         DateTime          @map("fecha_inicio")
  fechaFin            DateTime          @map("fecha_fin")
  fechaFinales        DateTime?         @map("fecha_finales") // Día D - Finales del torneo
  fechaLimiteInscr    DateTime          @map("fecha_limite_inscr")
  flyerUrl            String            @map("flyer_url")
  estado              TournamentStatus  @default(BORRADOR)
  costoInscripcion    Decimal           @map("costo_inscripcion") @db.Decimal(10, 2)
  // Campos legacy
  sede                String?
  direccion           String?
  mapsUrl             String?           @map("maps_url")
  // Nueva relación con Sede
  sedeId              String?           @map("sede_id")
  minutosPorPartido   Int               @default(60) @map("minutos_por_partido")
  precioPelota        Decimal?          @map("precio_pelota") @db.Decimal(10, 2)
  habilitarBancard    Boolean           @default(false) @map("habilitar_bancard")
  comisionPorcentaje  Decimal?          @map("comision_porcentaje") @db.Decimal(5, 2)
  slug                String?           @unique
  organizadorId       String            @map("organizador_id")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  // Relaciones
  organizador       User                  @relation("OrganizadorTorneos", fields: [organizadorId], references: [id])
  sedePrincipal     Sede?                 @relation("SedePrincipal", fields: [sedeId], references: [id])
  categorias        TournamentCategory[]
  modalidades       TournamentModalidad[]
  torneoSedes       TorneoSede[]
  torneoCanchas     TorneoCancha[]
  pelotasRonda      TorneoPelotasRonda[]
  ayudantes         TorneoAyudante[]
  inscripciones     Inscripcion[]
  partidos          Match[]
  fotos             Foto[]
  sponsors          TournamentSponsor[]
  premios           TournamentPremio[]
  historialPuntos   HistorialPuntos[]
  cuentasBancarias  CuentaBancaria[]
  banners              Banner[]
  publicacionesFeed    PublicacionFeed[] @relation("FeedTournament")
  movimientos          MovimientoFinanciero[]
  auspiciantesEspecie  AuspicianteEspecie[]
  
  // Relaciones V2 - Sistema de gestión integral
  comision             TorneoComision?
  checklistItems       ChecklistItem[]
  notificaciones       NotificacionEnviada[]
  
  // NUEVO: Disponibilidad de días para sorteo de slots
  disponibilidadDias   TorneoDisponibilidadDia[]
  
  // NUEVO: Multiplicador de puntos para rankings
  multiplicadorPuntos  Float        @default(1.0) @map("multiplicador_puntos")
  
  // NUEVO: Circuitos
  circuitosParticipa   TorneoCircuito[]
  esFinalDeCircuito    Circuito?      @relation("CircuitoFinal")
  
  // NUEVO: Configuración de Finales (canchas y hora de inicio)
  canchasFinales       String[]       @map("canchas_finales") // Array de TorneoCancha IDs
  horaInicioFinales    String?        @map("hora_inicio_finales") // Ej: "09:00"
  horaFinFinales       String?        @map("hora_fin_finales")   // Ej: "23:00"

  @@map("tournaments")
}

model TournamentCategory {
  id                    String           @id @default(uuid())
  tournamentId          String           @map("tournament_id")
  categoryId            String           @map("category_id")
  inscripcionAbierta    Boolean          @default(true) @map("inscripcion_abierta")
  estado                CategoriaEstado  @default(INSCRIPCIONES_ABIERTAS)
  fechaInicioPartidos   String?          @map("fecha_inicio_partidos")
  // NUEVO: Referencia a fixture versionado
  fixtureVersionId      String?          @map("fixture_version_id") @unique
  createdAt             DateTime         @default(now()) @map("created_at")

  tournament      Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category        Category         @relation(fields: [categoryId], references: [id])
  // NUEVO: Relación con fixture
  fixtureVersion  FixtureVersion?  @relation(fields: [fixtureVersionId], references: [id])

  @@unique([tournamentId, categoryId])
  @@map("tournament_categories")
}

model TournamentModalidad {
  id              String          @id @default(uuid())
  tournamentId    String          @map("tournament_id")
  modalidadConfigId String        @map("modalidad_config_id")
  createdAt       DateTime        @default(now()) @map("created_at")

  tournament      Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  modalidadConfig ModalidadConfig @relation(fields: [modalidadConfigId], references: [id])

  @@unique([tournamentId, modalidadConfigId])
  @@map("tournament_modalidades")
}

model TournamentSponsor {
  id           String   @id @default(uuid())
  tournamentId String   @map("tournament_id")
  nombre       String
  logoUrl      String?  @map("logo_url")
  nivel        String   @default("BRONCE") // ORO, PLATA, BRONCE
  orden        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  auspiciosEspecie AuspicianteEspecie[]

  @@map("tournament_sponsors")
}

model TournamentPremio {
  id           String   @id @default(uuid())
  tournamentId String   @map("tournament_id")
  puesto       String   // "1ro", "2do", "3ro", etc.
  descripcion  String
  valor        Decimal? @db.Decimal(10, 2)
  otros        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("tournament_premios")
}

// NUEVO: Fixture Versionado
model FixtureVersion {
  id                  String                @id @default(uuid())
  tournamentId        String                @map("tournament_id")
  categoryId          String                @map("category_id")
  version             Int                   @default(1)
  estado              FixtureVersionEstado  @default(BORRADOR)
  // Definición del bracket completo como JSON
  definicion          Json                  // { rondas: [...], slots: [...] }
  totalPartidos       Int                   @map("total_partidos")
  createdAt           DateTime              @default(now()) @map("created_at")
  publicadoAt         DateTime?             @map("publicado_at")
  archivadoAt         DateTime?             @map("archivado_at")

  // Relaciones
  tournamentCategory  TournamentCategory?
  partidos            Match[]

  @@unique([tournamentId, categoryId, version])
  @@map("fixture_versions")
}

// ═══════════════════════════════════════════════════════
// MÓDULO 3: INSCRIPCIONES Y PAGOS (MODIFICADO)
// ═══════════════════════════════════════════════════════

// ELIMINADO: model Pareja - ahora los jugadores están inline en Inscripcion

model Inscripcion {
  id           String                @id @default(uuid())
  tournamentId String                @map("tournament_id")
  categoryId   String                @map("category_id")
  
  // NUEVO: Jugadores inline (reemplaza tabla Pareja)
  jugador1Id        String   @map("jugador1_id")
  jugador2Id        String?  @map("jugador2_id")  // Nullable hasta que acepte
  jugador2Documento String   @map("jugador2_documento")
  jugador2Email     String?  @map("jugador2_email") // Para invitar
  
  estado       InscripcionEstado     @default(PENDIENTE_PAGO)
  modoPago     ModoPagoInscripcion?  @map("modo_pago")
  notas        String?               @db.Text
  
  // NUEVO: Estado de clasificación en el torneo (actualizado en tiempo real)
  estadoClasificacion String?          @map("estado_clasificacion") // PENDIENTE, CLASIFICADO_DIRECTO, REPECHAJE, EN_BRACKET, ELIMINADO
  posicionClasificacion Int?           @map("posicion_clasificacion") // Orden de clasificación (1, 2, 3...)
  rondaClasificacion  String?          @map("ronda_clasificacion") // ZONA, REPECHAJE, OCTAVOS, CUARTOS, etc.
  
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  // Relaciones
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category     Category          @relation(fields: [categoryId], references: [id])
  
  // NUEVO: Relaciones directas a usuarios
  jugador1     User              @relation("InscripcionJugador1", fields: [jugador1Id], references: [id])
  jugador2     User?             @relation("InscripcionJugador2", fields: [jugador2Id], references: [id])
  
  // Relaciones a matches (reemplaza relaciones desde Pareja)
  partidosComoP1    Match[] @relation("InscripcionP1")
  partidosComoP2    Match[] @relation("InscripcionP2")
  partidosGanados   Match[] @relation("InscripcionGanadora")
  partidosPerdidos  Match[] @relation("InscripcionPerdedora")
  
  pagos        Pago[]
  comprobantes ComprobantePago[]
  invitacion   InvitacionJugador?

  @@unique([tournamentId, categoryId, jugador1Id, jugador2Documento])
  @@map("inscripciones")
}

// NUEVO: Invitaciones a jugador2 (sistema de invitación explícito)
model InvitacionJugador {
  id              String   @id @default(uuid())
  inscripcionId   String   @unique @map("inscripcion_id")
  email           String   // Email del invitado
  token           String   @unique // Token para aceptar invitación
  estado          String   @default("PENDIENTE") // PENDIENTE, ACEPTADA, RECHAZADA, EXPIRADA
  expiraAt        DateTime @map("expira_at")
  createdAt       DateTime @default(now()) @map("created_at")
  respondedAt     DateTime? @map("responded_at")

  // Relaciones
  inscripcion     Inscripcion @relation(fields: [inscripcionId], references: [id], onDelete: Cascade)

  @@map("invitaciones_jugador")
}

model Pago {
  id             String       @id @default(uuid())
  inscripcionId  String       @map("inscripcion_id")
  jugadorId      String?      @map("jugador_id") // Quién realizó el pago
  metodoPago     MetodoPago   @map("metodo_pago")
  monto          Decimal      @db.Decimal(10, 2)
  comision       Decimal      @db.Decimal(10, 2)
  estado         PagoEstado   @default(PENDIENTE)
  transactionId  String?      @map("transaction_id")
  fechaPago      DateTime?    @map("fecha_pago")
  fechaConfirm   DateTime?    @map("fecha_confirmacion")
  createdAt      DateTime     @default(now()) @map("created_at")

  inscripcion Inscripcion @relation(fields: [inscripcionId], references: [id], onDelete: Cascade)
  jugador     User?       @relation("PagosJugador", fields: [jugadorId], references: [id])

  @@map("pagos")
}

model ComprobantePago {
  id             String            @id @default(uuid())
  inscripcionId  String            @map("inscripcion_id")
  url            String
  estado         ModerationStatus  @default(PENDIENTE)
  motivoRechazo  String?           @map("motivo_rechazo") @db.Text
  createdAt      DateTime          @default(now()) @map("created_at")

  inscripcion Inscripcion @relation(fields: [inscripcionId], references: [id], onDelete: Cascade)

  @@map("comprobantes_pago")
}

model CuentaBancaria {
  id                    String     @id @default(uuid())
  tournamentId          String     @map("tournament_id")
  banco                 String
  titular               String
  cedulaRuc             String     @map("cedula_ruc")
  nroCuenta             String?    @map("nro_cuenta")
  aliasSpi              String?    @map("alias_spi")
  telefonoComprobante   String?    @map("telefono_comprobante")
  activa                Boolean    @default(true)
  createdAt             DateTime   @default(now()) @map("created_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("cuentas_bancarias")
}

// ═══════════════════════════════════════════════════════
// MÓDULO 4: PARTIDOS Y RESULTADOS (MODIFICADO)
// ═══════════════════════════════════════════════════════

model Match {
  id                 String       @id @default(uuid())
  tournamentId       String       @map("tournament_id")
  categoryId         String       @map("category_id")
  
  // NUEVO: Referencia a fixture versionado
  fixtureVersionId   String?      @map("fixture_version_id")
  
  ronda              String
  numeroRonda        Int          @map("numero_ronda")
  
  // MODIFICADO: Ahora referencia Inscripcion en lugar de Pareja
  inscripcion1Id     String?      @map("inscripcion1_id")
  inscripcion2Id     String?      @map("inscripcion2_id")
  
  torneoCanchaId     String?      @map("torneo_cancha_id")
  sedeCanchaId       String?      @map("sede_cancha_id") // Para alquileres
  fechaProgramada    DateTime?    @map("fecha_programada") @db.Date
  horaProgramada     String?      @map("hora_programada")
  horaFinEstimada    String?      @map("hora_fin_estimada")
  estado             MatchStatus  @default(PROGRAMADO)
  
  // MODIFICADO: Referencias a inscripciones ganadora/perdedora
  inscripcionGanadoraId  String?  @map("inscripcion_ganadora_id")
  inscripcionPerdedoraId String?  @map("inscripcion_perdedora_id")
  
  // Resultados
  set1Pareja1        Int?         @map("set1_pareja1")
  set1Pareja2        Int?         @map("set1_pareja2")
  set2Pareja1        Int?         @map("set2_pareja1")
  set2Pareja2        Int?         @map("set2_pareja2")
  set3Pareja1        Int?         @map("set3_pareja1")
  set3Pareja2        Int?         @map("set3_pareja2")
  
  // NUEVO: Formato del set 3
  formatoSet3        FormatoSet3? @default(SET_COMPLETO) @map("formato_set3")
  
  // NUEVO: Marcador en vivo (JSON flexible)
  liveScore          Json?        @map("live_score") // { setActual: 1, gameP1: 2, gameP2: 3, puntoP1: 30, puntoP2: 40, saque: 1, historial: [...] }
  
  // NUEVO: Duración del partido
  duracionMinutos    Int?         @map("duracion_minutos")
  horaInicioReal     DateTime?    @map("hora_inicio_real")
  horaFinReal        DateTime?    @map("hora_fin_real")
  
  // Navegación en bracket
  partidoSiguienteId      String?  @map("partido_siguiente_id")
  posicionEnSiguiente     Int?     @map("posicion_en_siguiente")
  partidoPerdedorSiguienteId  String?  @map("partido_perdedor_siguiente_id")
  posicionEnPerdedor          Int?     @map("posicion_en_perdedor")
  
  // NUEVO: Sistema Zona + Repechaje + Bracket (Opción A)
  esBye                   Boolean  @default(false) @map("es_bye")
  tipoEntrada1            String?  @map("tipo_entrada1")  // INSCRIPCION | GANADOR_ZONA | GANADOR_REPECHAJE | BYE_DIRECTO
  tipoEntrada2            String?  @map("tipo_entrada2")
  partidoOrigen1Id        String?  @map("partido_origen1_id")  // De qué partido viene entrada1
  partidoOrigen2Id        String?  @map("partido_origen2_id")  // De qué partido viene entrada2
  
  observaciones      String?      @db.Text
  
  // NUEVO: Para retiros/descalificaciones - indica qué pareja (1 o 2)
  parejaRetirada     Int?         @map("pareja_retirada")  // 1 o 2
  razonResultado     String?      @map("razon_resultado")   // "lesion", "descalificacion", etc.
  
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  // Relaciones
  tournament       Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category         Category         @relation(fields: [categoryId], references: [id])
  fixtureVersion   FixtureVersion?  @relation(fields: [fixtureVersionId], references: [id])
  
  // MODIFICADO: Relaciones a Inscripcion
  inscripcion1     Inscripcion?     @relation("InscripcionP1", fields: [inscripcion1Id], references: [id])
  inscripcion2     Inscripcion?     @relation("InscripcionP2", fields: [inscripcion2Id], references: [id])
  inscripcionGanadora   Inscripcion? @relation("InscripcionGanadora", fields: [inscripcionGanadoraId], references: [id])
  inscripcionPerdedora  Inscripcion? @relation("InscripcionPerdedora", fields: [inscripcionPerdedoraId], references: [id])
  
  torneoCancha     TorneoCancha?    @relation(fields: [torneoCanchaId], references: [id])
  sedeCancha       SedeCancha?      @relation(fields: [sedeCanchaId], references: [id])
  slot             TorneoSlot?      @relation("SlotPartido")
  
  publicacionesFeed PublicacionFeed[]

  @@map("matches")
}

// ═══════════════════════════════════════════════════════
// MÓDULO 5: RANKINGS
// ═══════════════════════════════════════════════════════

model Ranking {
  id                  String       @id @default(uuid())
  jugadorId           String       @map("jugador_id")
  tipoRanking         TipoRanking  @map("tipo_ranking")
  alcance             String
  genero              Gender
  puntosTotales       Int          @default(0) @map("puntos_totales")
  posicion            Int
  posicionAnterior    Int?         @map("posicion_anterior")
  torneosJugados      Int          @default(0) @map("torneos_jugados")
  victorias           Int          @default(0)
  derrotas            Int          @default(0)
  porcentajeVictorias Decimal?     @map("porcentaje_victorias") @db.Decimal(5, 2)
  rachaActual         Int          @default(0) @map("racha_actual")
  mejorPosicion       Int?         @map("mejor_posicion")
  campeonatos         Int          @default(0)
  temporada           String       @default("2026")
  ultimaActualizacion DateTime     @default(now()) @map("ultima_actualizacion")

  jugador User @relation(fields: [jugadorId], references: [id], onDelete: Cascade)

  @@unique([jugadorId, tipoRanking, alcance, temporada])
  @@map("rankings")
}

model HistorialPuntos {
  id            String   @id @default(uuid())
  jugadorId     String   @map("jugador_id")
  tournamentId  String   @map("tournament_id")
  categoryId    String   @map("category_id")
  posicionFinal String   @map("posicion_final") // "1ro", "2do", etc.
  puntosGanados Int      @map("puntos_ganados") // Ya con multiplicador aplicado
  puntosBase    Int      @map("puntos_base")    // Sin multiplicador
  multiplicadorAplicado Float @default(1.0) @map("multiplicador_aplicado")
  fechaTorneo   DateTime @map("fecha_torneo") @db.Date
  createdAt     DateTime @default(now()) @map("created_at")

  jugador    User       @relation(fields: [jugadorId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id])
  category   Category   @relation(fields: [categoryId], references: [id])

  @@map("historial_puntos")
}

model ConfiguracionPuntos {
  id            String   @id @default(uuid())
  posicion      String   @unique  // "1ro", "2do", "3ro", "3ro-4to" (semis), "5to-8vo" (cuartos), etc.
  descripcion   String?           // "Campeón", "Subcampeón", etc.
  puntosBase    Int      @map("puntos_base")
  orden         Int               // 1, 2, 3, 4... para ordenar
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("configuracion_puntos")
}

model ConfiguracionSistema {
  id        String   @id @default(uuid())
  clave     String   @unique
  valor     String
  descripcion String? @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("configuracion_sistema")
}

// ═══════════════════════════════════════════════════════
// MÓDULO 6: SOCIAL
// ═══════════════════════════════════════════════════════

model Seguimiento {
  id                     String   @id @default(uuid())
  seguidorId             String   @map("seguidor_id")
  seguidoId              String   @map("seguido_id")
  notificacionesActivas  Boolean  @default(true) @map("notificaciones_activas")
  createdAt              DateTime @default(now()) @map("created_at")

  seguidor User @relation("UsuarioSeguidor", fields: [seguidorId], references: [id], onDelete: Cascade)
  seguido  User @relation("UsuarioSeguido", fields: [seguidoId], references: [id], onDelete: Cascade)

  @@unique([seguidorId, seguidoId])
  @@map("seguimientos")
}

model MensajePrivado {
  id             String   @id @default(uuid())
  remitenteId    String   @map("remitente_id")
  destinatarioId String   @map("destinatario_id")
  contenido      String   @db.Text
  leido          Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  remitente    User @relation("MensajeRemitente", fields: [remitenteId], references: [id], onDelete: Cascade)
  destinatario User @relation("MensajeDestinatario", fields: [destinatarioId], references: [id], onDelete: Cascade)

  @@map("mensajes_privados")
}

model SolicitudJugar {
  id             String          @id @default(uuid())
  emisorId       String          @map("emisor_id")
  receptorId     String          @map("receptor_id")
  fechaPropuesta DateTime        @map("fecha_propuesta")
  hora           String
  lugar          String
  mensaje        String?         @db.Text
  estado         SolicitudEstado @default(PENDIENTE)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  emisor   User @relation("SolicitudRemitente", fields: [emisorId], references: [id], onDelete: Cascade)
  receptor User @relation("SolicitudDestinatario", fields: [receptorId], references: [id], onDelete: Cascade)

  @@map("solicitudes_jugar")
}

model Logro {
  id              String   @id @default(uuid())
  nombre          String   @unique
  descripcion     String   @db.Text
  icono           String
  condicion       String   @db.Text
  categoria       String   @default("general")
  requierePremium Boolean  @default(false) @map("requiere_premium")
  orden           Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")

  usuariosQueDesbloquearon UsuarioLogro[]

  @@map("logros")
}

model UsuarioLogro {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  logroId         String   @map("logro_id")
  fechaDesbloqueo DateTime @default(now()) @map("fecha_desbloqueo")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  logro Logro @relation(fields: [logroId], references: [id], onDelete: Cascade)

  @@unique([userId, logroId])
  @@map("usuario_logros")
}

model Bloqueo {
  id           String   @id @default(uuid())
  bloqueadorId String   @map("bloqueador_id")
  bloqueadoId  String   @map("bloqueado_id")
  createdAt    DateTime @default(now()) @map("created_at")

  bloqueador User @relation("BloqueoBloqueador", fields: [bloqueadorId], references: [id], onDelete: Cascade)
  bloqueado  User @relation("BloqueoBloqueado", fields: [bloqueadoId], references: [id], onDelete: Cascade)

  @@unique([bloqueadorId, bloqueadoId])
  @@map("bloqueos")
}

model Reporte {
  id           String          @id @default(uuid())
  reportadorId String          @map("reportador_id")
  reportadoId  String          @map("reportado_id")
  motivo       String
  descripcion  String?         @db.Text
  estado       SolicitudEstado @default(PENDIENTE)
  createdAt    DateTime        @default(now()) @map("created_at")

  reportador User @relation("ReporteReportador", fields: [reportadorId], references: [id], onDelete: Cascade)
  reportado  User @relation("ReporteReportado", fields: [reportadoId], references: [id], onDelete: Cascade)

  @@map("reportes")
}

// ═══════════════════════════════════════════════════════
// MÓDULO 7: GALERÍA Y FOTOS
// ═══════════════════════════════════════════════════════

model Foto {
  id                  String            @id @default(uuid())
  userId              String            @map("user_id")
  tournamentId        String?           @map("tournament_id")
  urlImagen           String            @map("url_imagen")
  urlThumbnail        String?           @map("url_thumbnail")
  cloudinaryPublicId  String?           @map("cloudinary_public_id")
  descripcion         String?           @db.VarChar(500)
  tipo                String            @default("PERSONAL")
  estadoModeracion    ModerationStatus  @default(PENDIENTE) @map("estado_moderacion")
  likesCount          Int               @default(0) @map("likes_count")
  comentariosCount    Int               @default(0) @map("comentarios_count")
  esPrivada           Boolean           @default(false) @map("es_privada")
  fechaSubida         DateTime          @default(now()) @map("fecha_subida")
  createdAt           DateTime          @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament?   @relation(fields: [tournamentId], references: [id])
  likes        Like[]
  comentarios  Comentario[]
  reportes     ReporteFoto[]
  albumFotos   AlbumFoto[]
  etiquetados       FotoJugador[]
  publicacionesFeed PublicacionFeed[]

  @@map("fotos")
}

model FotoJugador {
  id        String   @id @default(uuid())
  fotoId    String   @map("foto_id")
  jugadorId String   @map("jugador_id")
  createdAt DateTime @default(now()) @map("created_at")

  foto    Foto @relation(fields: [fotoId], references: [id], onDelete: Cascade)
  jugador User @relation(fields: [jugadorId], references: [id], onDelete: Cascade)

  @@unique([fotoId, jugadorId])
  @@map("foto_jugadores")
}

model Like {
  id        String   @id @default(uuid())
  fotoId    String   @map("foto_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  foto Foto @relation(fields: [fotoId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([fotoId, userId])
  @@map("likes")
}

model Comentario {
  id        String   @id @default(uuid())
  fotoId    String   @map("foto_id")
  userId    String   @map("user_id")
  contenido String   @db.Text
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")

  foto Foto @relation(fields: [fotoId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comentarios")
}

model Album {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  nombre      String
  descripcion String?  @db.Text
  portadaUrl  String?  @map("portada_url")
  createdAt   DateTime @default(now()) @map("created_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fotos AlbumFoto[]

  @@map("albumes")
}

model AlbumFoto {
  id      String @id @default(uuid())
  albumId String @map("album_id")
  fotoId  String @map("foto_id")
  orden   Int

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)
  foto  Foto  @relation(fields: [fotoId], references: [id], onDelete: Cascade)

  @@unique([albumId, fotoId])
  @@map("album_fotos")
}

model ReporteFoto {
  id        String          @id @default(uuid())
  fotoId    String          @map("foto_id")
  userId    String          @map("user_id")
  motivo    String
  estado    SolicitudEstado @default(PENDIENTE)
  createdAt DateTime        @default(now()) @map("created_at")

  foto Foto @relation(fields: [fotoId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reportes_fotos")
}

model FotoPerfilModeracion {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  fotoUrl       String           @map("foto_url")
  estado        ModerationStatus @default(PENDIENTE)
  motivoRechazo String?          @map("motivo_rechazo") @db.Text
  createdAt     DateTime         @default(now()) @map("created_at")

  usuario User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("fotos_perfil_moderacion")
}

// ═══════════════════════════════════════════════════════
// MÓDULO 8: SUSCRIPCIONES Y PREMIUM
// ═══════════════════════════════════════════════════════

model PlanPremium {
  id              String   @id @default(uuid())
  nombre          String   @unique
  tipo            PlanTipo @default(MENSUAL)
  precioMensual   Decimal  @map("precio_mensual") @db.Decimal(10, 2)
  caracteristicas String   @db.Text
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  suscripciones Suscripcion[]

  @@map("planes_premium")
}

model Suscripcion {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  planId          String             @map("plan_id")
  periodo         PeriodoSuscripcion
  precio          Decimal            @db.Decimal(10, 2)
  estado          SuscripcionEstado  @default(PENDIENTE)
  fechaInicio     DateTime           @map("fecha_inicio")
  fechaFin        DateTime           @map("fecha_fin")
  fechaRenovacion DateTime?          @map("fecha_renovacion")
  autoRenovar     Boolean            @default(true) @map("auto_renovar")
  metodoPagoId    String?            @map("metodo_pago_id")
  cuponAplicado   String?            @map("cupon_aplicado")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan PlanPremium @relation(fields: [planId], references: [id])

  @@map("suscripciones")
}

model Cupon {
  id              String   @id @default(uuid())
  userId          String?  @map("user_id")
  codigo          String   @unique
  tipo            String
  valor           Decimal  @db.Decimal(10, 2)
  fechaInicio     DateTime @map("fecha_inicio")
  fechaExpiracion DateTime @map("fecha_expiracion")
  limiteUsos      Int      @map("limite_usos")
  usosActuales    Int      @default(0) @map("usos_actuales")
  estado          String   @default("ACTIVO")
  createdAt       DateTime @default(now()) @map("created_at")

  usuario User? @relation("CuponesUsuario", fields: [userId], references: [id], onDelete: SetNull)

  @@map("cupones")
}

model Notificacion {
  id           String            @id @default(uuid())
  userId       String            @map("user_id")
  tipo         TipoNotificacion
  titulo       String?           @db.VarChar(200)
  contenido    String            @db.Text
  enlace       String?           @db.VarChar(500)
  leida        Boolean           @default(false)
  emailEnviado Boolean           @default(false) @map("email_enviado")
  smsEnviado   Boolean           @default(false) @map("sms_enviado")
  createdAt    DateTime          @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notificaciones")
}

model PreferenciaNotificacion {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  tipoNotificacion TipoNotificacion  @map("tipo_notificacion")
  recibirEmail     Boolean           @default(true) @map("recibir_email")
  recibirSms       Boolean           @default(true) @map("recibir_sms")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tipoNotificacion])
  @@map("preferencias_notificacion")
}

model SmsLog {
  id               String            @id @default(uuid())
  userId           String?           @map("user_id")
  telefono         String
  mensaje          String            @db.VarChar(320)
  tipo             TipoNotificacion?
  exitoso          Boolean           @default(true)
  providerResponse String?           @map("provider_response") @db.Text
  costoEstimado    Float             @default(0) @map("costo_estimado")
  createdAt        DateTime          @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@map("sms_logs")
}

// ═══════════════════════════════════════════════════════
// MÓDULO: GESTIÓN DE CATEGORÍAS Y ASCENSOS
// ═══════════════════════════════════════════════════════

model ReglaAscenso {
  id                       String   @id @default(uuid())
  categoriaOrigenId        String   @map("categoria_origen_id")
  categoriaDestinoId       String   @map("categoria_destino_id")
  
  // Cantidad de campeonatos requeridos
  campeonatosRequeridos    Int      @map("campeonatos_requeridos")
  
  // Tipo de conteo: CONSECUTIVOS o ALTERNADOS
  tipoConteo               String   @default("ALTERNADOS") @map("tipo_conteo")
  
  // Período de validez (normalmente 12 meses)
  mesesVentana             Int      @default(12) @map("meses_ventana")
  
  // Si ser finalista también cuenta (para categorías altas)
  finalistaCalifica        Boolean  @default(false) @map("finalista_califica")
  
  // Restricciones adicionales
  minimoTorneosJugados     Int      @default(0) @map("minimo_torneos_jugados")
  
  activa                   Boolean  @default(true)
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  categoriaOrigen  Category @relation("CategoriaOrigen", fields: [categoriaOrigenId], references: [id])
  categoriaDestino Category @relation("CategoriaDestino", fields: [categoriaDestinoId], references: [id])

  @@unique([categoriaOrigenId, categoriaDestinoId])
  @@map("reglas_ascenso")
}

model HistorialCategoria {
  id                  String              @id @default(uuid())
  userId              String              @map("user_id")
  categoriaAnteriorId String?             @map("categoria_anterior_id")
  categoriaNuevaId    String              @map("categoria_nueva_id")
  tipo                TipoCambioCategoria
  motivo              String              @db.Text
  tournamentId        String?             @map("tournament_id")
  realizadoPor        String?             @map("realizado_por")
  createdAt           DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("historial_categorias")
}

model AscensoPendiente {
  id                  String              @id @default(uuid())
  userId              String              @map("user_id")
  categoriaActualId   String              @map("categoria_actual_id")
  categoriaNuevaId    String              @map("categoria_nueva_id")
  
  // Evidencia de cumplimiento
  torneosGanadosIds   String[]            @map("torneos_ganados_ids")
  fechaCalculo        DateTime            @map("fecha_calculo")
  
  // Estado del ascenso
  estado              EstadoAscenso       @default(PENDIENTE)
  revisadoPorId       String?             @map("revisado_por_id")
  fechaRevision       DateTime?           @map("fecha_revision")
  notasRevision       String?             @map("notas_revision") @db.Text
  
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoriaActual Category @relation("CategoriaActualAscensos", fields: [categoriaActualId], references: [id])
  categoriaNueva  Category @relation("AscensoPendienteNueva", fields: [categoriaNuevaId], references: [id])

  @@map("ascensos_pendientes")
}

// ═══════════════════════════════════════════════════════
// MÓDULO 12: PUBLICIDAD Y BANNERS
// ═══════════════════════════════════════════════════════

model Banner {
  id                 String      @id @default(uuid())
  titulo             String      @db.VarChar(200)
  imagenUrl          String      @map("imagen_url")
  imagenPublicId     String?     @map("imagen_public_id")
  linkUrl            String?     @map("link_url") @db.VarChar(500)
  zona               BannerZona
  activo             Boolean     @default(true)
  fechaInicio        DateTime?   @map("fecha_inicio")
  fechaFin           DateTime?   @map("fecha_fin")
  orden              Int         @default(0)
  clicks             Int         @default(0)
  impresiones        Int         @default(0)
  anunciante         String?     @db.VarChar(200)
  torneoId           String?     @map("torneo_id")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  torneo             Tournament? @relation(fields: [torneoId], references: [id], onDelete: SetNull)

  @@index([zona, activo])
  @@index([torneoId])
  @@map("banners")
}

// ═══════════════════════════════════════════════════════
// MÓDULO 13: FEED SOCIAL
// ═══════════════════════════════════════════════════════

model PublicacionFeed {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  tipo            TipoPublicacion
  contenido       String?          @db.Text
  fotoId          String?          @map("foto_id")
  matchId         String?          @map("match_id")
  tournamentId    String?          @map("tournament_id")
  categoriaId     String?          @map("categoria_id")
  datosExtra      String?          @map("datos_extra") @db.Text
  likesCount      Int              @default(0) @map("likes_count")
  comentariosCount Int             @default(0) @map("comentarios_count")
  createdAt       DateTime         @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  foto       Foto?       @relation(fields: [fotoId], references: [id], onDelete: SetNull)
  match      Match?      @relation(fields: [matchId], references: [id], onDelete: SetNull)
  tournament Tournament? @relation("FeedTournament", fields: [tournamentId], references: [id], onDelete: SetNull)

  likesPublicacion    LikePublicacion[]
  comentariosPublicacion ComentarioPublicacion[]

  @@index([userId, createdAt])
  @@index([tipo])
  @@map("publicaciones_feed")
}

model LikePublicacion {
  id             String   @id @default(uuid())
  publicacionId  String   @map("publicacion_id")
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  publicacion PublicacionFeed @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([publicacionId, userId])
  @@map("likes_publicaciones")
}

model ComentarioPublicacion {
  id             String   @id @default(uuid())
  publicacionId  String   @map("publicacion_id")
  userId         String   @map("user_id")
  contenido      String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  publicacion PublicacionFeed @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comentarios_publicaciones")
}

// ═══════════════════════════════════════════════════════
// MÓDULO: ALERTAS PERSONALIZADAS (PREMIUM)
// ═══════════════════════════════════════════════════════

enum TipoAlertaPersonalizada {
  TORNEO_EN_MI_CIUDAD
  TORNEO_MI_CATEGORIA
  RIVAL_INSCRITO
  RANKING_CAMBIO
}

model AlertaPersonalizada {
  id        String                  @id @default(uuid())
  userId    String                  @map("user_id")
  tipo      TipoAlertaPersonalizada
  activa    Boolean                 @default(true)
  config    Json?
  createdAt DateTime                @default(now()) @map("created_at")
  updatedAt DateTime                @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tipo])
  @@map("alertas_personalizadas")
}

// ═══════════════════════════════════════════════════════
// MÓDULO: FINANZAS (Movimientos e Ingresos/Egresos)
// ═══════════════════════════════════════════════════════

model MovimientoFinanciero {
  id              String              @id @default(uuid())
  tournamentId    String              @map("tournament_id")
  tipo            TipoMovimiento
  categoria       CategoriaMovimiento
  concepto        String              @db.VarChar(300)
  monto           Decimal             @db.Decimal(10, 2)
  fecha           DateTime            @default(now())
  observaciones   String?             @db.Text
  creadoPor       String              @map("creado_por")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  tournament      Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  creador         User                @relation("MovimientosCreados", fields: [creadoPor], references: [id])

  @@index([tournamentId, tipo])
  @@map("movimientos_financieros")
}

model AuspicianteEspecie {
  id              String      @id @default(uuid())
  tournamentId    String      @map("tournament_id")
  sponsorId       String?     @map("sponsor_id")
  nombre          String
  descripcion     String      @db.Text
  valorEstimado   Decimal     @map("valor_estimado") @db.Decimal(10, 2)
  fecha           DateTime    @default(now())
  observaciones   String?     @db.Text
  creadoPor       String      @map("creado_por")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tournament      Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  sponsor         TournamentSponsor?  @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  creador         User                @relation("AuspiciosCreados", fields: [creadoPor], references: [id])

  @@index([tournamentId])
  @@map("auspiciantes_especie")
}

// ═══════════════════════════════════════════════════════
// INSTRUCTORES
// ═══════════════════════════════════════════════════════

model SolicitudInstructor {
  id                String          @id @default(uuid())
  userId            String          @map("user_id")
  experienciaAnios  Int             @map("experiencia_anios")
  certificaciones   String?         @db.Text
  especialidades    String?         @db.Text
  nivelesEnsenanza  String?         @map("niveles_ensenanza") @db.Text
  descripcion       String?         @db.Text
  precioIndividual  Int?            @map("precio_individual")
  precioGrupal      Int?            @map("precio_grupal")
  ciudades          String?         @db.Text
  estado            SolicitudEstado @default(PENDIENTE)
  motivo            String?         @db.Text
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  user User @relation("InstructorSolicitudes", fields: [userId], references: [id], onDelete: Cascade)

  @@map("solicitudes_instructor")
}

model Instructor {
  id                String            @id @default(uuid())
  userId            String            @unique @map("user_id")
  estado            InstructorEstado  @default(APROBADO)
  experienciaAnios  Int               @map("experiencia_anios")
  certificaciones   String?           @db.Text
  especialidades    String?           @db.Text
  nivelesEnsenanza  String?           @map("niveles_ensenanza") @db.Text
  descripcion       String?           @db.Text
  precioIndividual  Int?              @map("precio_individual")
  precioGrupal      Int?              @map("precio_grupal")
  aceptaDomicilio   Boolean           @default(false) @map("acepta_domicilio")
  verificado        Boolean           @default(false)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user             User                        @relation("InstructorProfile", fields: [userId], references: [id], onDelete: Cascade)
  ubicaciones      InstructorUbicacion[]
  disponibilidades InstructorDisponibilidad[]
  bloqueos         InstructorBloqueo[]
  reservas         ReservaInstructor[]
  pagos            PagoInstructor[]

  @@map("instructores")
}

model InstructorUbicacion {
  id            String   @id @default(uuid())
  instructorId  String   @map("instructor_id")
  sedeId        String?  @map("sede_id")
  nombreCustom  String?  @map("nombre_custom")
  ciudad        String
  esPrincipal   Boolean  @default(false) @map("es_principal")
  activa        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  sede       Sede?      @relation(fields: [sedeId], references: [id])

  @@map("instructor_ubicaciones")
}

model InstructorDisponibilidad {
  id            String   @id @default(uuid())
  instructorId  String   @map("instructor_id")
  diaSemana     Int      @map("dia_semana")
  horaInicio    String   @map("hora_inicio")
  horaFin       String   @map("hora_fin")
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@map("instructor_disponibilidad")
}

model InstructorBloqueo {
  id            String   @id @default(uuid())
  instructorId  String   @map("instructor_id")
  fechaInicio   DateTime @map("fecha_inicio") @db.Date
  fechaFin      DateTime @map("fecha_fin") @db.Date
  motivo        String?
  createdAt     DateTime @default(now()) @map("created_at")

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@map("instructor_bloqueos")
}

model ReservaInstructor {
  id              String        @id @default(uuid())
  instructorId    String        @map("instructor_id")
  solicitanteId   String?       @map("solicitante_id")
  tipo            TipoClase
  fecha           DateTime      @db.Date
  horaInicio      String        @map("hora_inicio")
  horaFin         String        @map("hora_fin")
  duracionMinutos Int           @map("duracion_minutos") @default(60)
  precio          Int
  estado          ReservaEstado @default(PENDIENTE)
  mensaje         String?       @db.Text
  respuesta       String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Fase 3: Gestión de instructor
  alumnoExternoNombre   String?   @map("alumno_externo_nombre")
  alumnoExternoTelefono String?   @map("alumno_externo_telefono")
  asistio               Boolean?  @map("asistio")
  pagado                Boolean   @default(false)
  metodoPago            String?   @map("metodo_pago")
  notas                 String?   @db.Text
  creadoPorInstructor   Boolean   @default(false) @map("creado_por_instructor")
  montoCobrado          Int?      @map("monto_cobrado")

  instructor  Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  solicitante User?      @relation("ReservasComoAlumno", fields: [solicitanteId], references: [id], onDelete: Cascade)
  pagos       PagoInstructor[]

  @@map("reservas_instructor")
}

model PagoInstructor {
  id                    String               @id @default(uuid())
  instructorId          String               @map("instructor_id")
  alumnoId              String?              @map("alumno_id")
  alumnoExternoNombre   String?              @map("alumno_externo_nombre")
  alumnoExternoTelefono String?              @map("alumno_externo_telefono")
  reservaId             String?              @map("reserva_id")
  monto                 Int
  metodoPago            MetodoPagoInstructor @map("metodo_pago")
  concepto              ConceptoPago         @default(CLASE)
  descripcion           String?              @db.Text
  fecha                 DateTime             @db.Date
  numeroRecibo          Int?                 @map("numero_recibo")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  instructor Instructor         @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  alumno     User?              @relation("PagosInstructorAlumno", fields: [alumnoId], references: [id], onDelete: SetNull)
  reserva    ReservaInstructor? @relation(fields: [reservaId], references: [id], onDelete: SetNull)

  @@map("pagos_instructor")
}

// ═══════════════════════════════════════════════════════
// MÓDULO: ALQUILERES Y RESERVAS DE CANCHAS
// ═══════════════════════════════════════════════════════

model AlquilerConfig {
  id                    String   @id @default(uuid())
  sedeId                String   @unique @map("sede_id")
  encargadoId           String?  @map("encargado_id")
  habilitado            Boolean  @default(false)
  requiereAprobacion    Boolean  @default(true) @map("requiere_aprobacion")
  duracionSlotMinutos   Int      @default(90) @map("duracion_slot_minutos")
  anticipacionMaxDias   Int      @default(14) @map("anticipacion_max_dias")
  cancelacionMinHoras   Int      @default(4) @map("cancelacion_min_horas")
  mensajeBienvenida     String?  @map("mensaje_bienvenida") @db.Text
  telefonoNotificaciones String? @map("telefono_notificaciones")
  emailNotificaciones   String?  @map("email_notificaciones")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  sede      Sede  @relation(fields: [sedeId], references: [id], onDelete: Cascade)
  encargado User? @relation(fields: [encargadoId], references: [id], onDelete: SetNull)

  @@map("alquiler_configs")
}

model AlquilerPrecio {
  id            String        @id @default(uuid())
  sedeId        String        @map("sede_id")
  tipoCancha    TipoCancha    @map("tipo_cancha")
  tipoDia       TipoDia       @map("tipo_dia")
  franja        FranjaHoraria
  precio        Int
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  sede Sede @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@unique([sedeId, tipoCancha, tipoDia, franja])
  @@map("alquiler_precios")
}

model AlquilerDisponibilidad {
  id            String   @id @default(uuid())
  sedeCanchaId  String   @map("sede_cancha_id")
  diaSemana     Int      @map("dia_semana")
  horaInicio    String   @map("hora_inicio")
  horaFin       String   @map("hora_fin")
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  sedeCancha SedeCancha @relation(fields: [sedeCanchaId], references: [id], onDelete: Cascade)

  @@map("alquiler_disponibilidades")
}

model AlquilerBloqueo {
  id            String    @id @default(uuid())
  sedeId        String    @map("sede_id")
  sedeCanchaId  String?   @map("sede_cancha_id")
  fechaInicio   DateTime  @map("fecha_inicio") @db.Date
  fechaFin      DateTime  @map("fecha_fin") @db.Date
  motivo        String?
  createdAt     DateTime  @default(now()) @map("created_at")

  sede       Sede        @relation(fields: [sedeId], references: [id], onDelete: Cascade)
  sedeCancha SedeCancha? @relation(fields: [sedeCanchaId], references: [id], onDelete: Cascade)

  @@map("alquiler_bloqueos")
}

model ReservaCancha {
  id                  String               @id @default(uuid())
  sedeCanchaId        String               @map("sede_cancha_id")
  userId              String?              @map("user_id")
  fecha               DateTime             @db.Date
  horaInicio          String               @map("hora_inicio")
  horaFin             String               @map("hora_fin")
  duracionMinutos     Int                  @map("duracion_minutos")
  precio              Int
  estado              ReservaCanchaEstado  @default(PENDIENTE)
  pagado              Boolean              @default(false)
  metodoPago          MetodoPagoAlquiler?  @map("metodo_pago")
  nombreExterno       String?              @map("nombre_externo")
  telefonoExterno     String?              @map("telefono_externo")
  creadoPorEncargado  Boolean              @default(false) @map("creado_por_encargado")
  canceladaPorEncargado Boolean            @default(false) @map("cancelada_por_encargado")
  compromisoPago      Boolean              @default(false) @map("compromiso_pago")
  notas               String?              @db.Text
  motivoRechazo       String?              @map("motivo_rechazo") @db.Text
  motivoCancelacion   String?              @map("motivo_cancelacion") @db.Text
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  sedeCancha SedeCancha @relation("ReservasCanchas", fields: [sedeCanchaId], references: [id], onDelete: Cascade)
  user       User?      @relation("ReservasCanchaUsuario", fields: [userId], references: [id], onDelete: SetNull)
  reservaMensualero ReservaMensualero?

  @@map("reservas_canchas")
}

// ═══════════════════════════════════════════════════════
// MENSUALEROS - Grupos recurrentes de alquiler
// ═══════════════════════════════════════════════════════

enum TipoPagoMensualero {
  MENSUAL_ANTICIPADO
  POR_DIA
}

enum EstadoMensualero {
  ACTIVO
  SUSPENDIDO
  CANCELADO
}

model GrupoMensualero {
  id                      String               @id @default(uuid())
  sedeId                  String               @map("sede_id")
  sedeCanchaId            String               @map("sede_cancha_id")
  nombre                  String
  diaSemana               Int                  @map("dia_semana")
  horaInicio              String               @map("hora_inicio")
  tipoPago                TipoPagoMensualero   @default(POR_DIA) @map("tipo_pago")
  precioPorHora           Int                  @map("precio_por_hora")
  duracionHoras           Int                  @default(2) @map("duracion_horas")
  estado                  EstadoMensualero     @default(ACTIVO)
  notas                   String?              @db.Text
  
  // Responsable/Capitan del grupo
  responsableUserId       String?              @map("responsable_user_id")
  responsableNombre       String?              @map("responsable_nombre")
  responsableTelefono     String?              @map("responsable_telefono")
  
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  sede                    Sede                 @relation(fields: [sedeId], references: [id], onDelete: Cascade)
  cancha                  SedeCancha           @relation(fields: [sedeCanchaId], references: [id], onDelete: Cascade)
  responsable             User?                @relation(fields: [responsableUserId], references: [id], onDelete: SetNull)
  jugadores               JugadorMensualero[]
  reservas                ReservaMensualero[]

  @@map("grupos_mensualeros")
}

model JugadorMensualero {
  id                String            @id @default(uuid())
  grupoId           String            @map("grupo_id")
  userId            String?           @map("user_id")
  nombreExterno     String?           @map("nombre_externo")
  telefonoExterno   String?           @map("telefono_externo")
  esTitular         Boolean           @default(true) @map("es_titular")
  createdAt         DateTime          @default(now()) @map("created_at")

  grupo             GrupoMensualero   @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  user              User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("jugadores_mensualeros")
}

model ReservaMensualero {
  id                String               @id @default(uuid())
  grupoId           String               @map("grupo_id")
  fecha             DateTime             @db.Date
  estado            ReservaCanchaEstado  @default(PENDIENTE)
  pagado            Boolean              @default(false)
  montoPagado       Int                  @default(0) @map("monto_pagado")
  metodoPago        MetodoPagoAlquiler?  @map("metodo_pago")
  notas             String?              @db.Text
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  reservaRealId     String?              @unique @map("reserva_real_id")
  reservaReal       ReservaCancha?       @relation(fields: [reservaRealId], references: [id])

  grupo             GrupoMensualero      @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@map("reservas_mensualeros")
}

// ═══════════════════════════════════════════════════════
// MÓDULO: FAIRPADEL CORE - Gestión de Plataforma
// ═══════════════════════════════════════════════════════

model FairpadelConfig {
  id          String   @id @default(uuid())
  clave       String   @unique
  valor       String
  descripcion String?  @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("fairpadel_config")
}

model TorneoComision {
  id               String    @id @default(uuid())
  tournamentId     String    @unique @map("tournament_id")
  montoEstimado    Int       @map("monto_estimado")
  montoPagado      Int       @default(0) @map("monto_pagado")
  estado           String    @default("PENDIENTE") // PENDIENTE, PARCIAL, PAGADO
  bloqueoActivo    Boolean   @default(false) @map("bloqueo_activo")
  rondaBloqueo     String?   @map("ronda_bloqueo") // CUARTOS, SEMIFINALES, FINAL
  comprobanteUrl   String?   @map("comprobante_url")
  comprobanteNotas String?   @map("comprobante_notas") @db.Text
  pagadoAt         DateTime? @map("pagado_at")
  revisadoPor      String?   @map("revisado_por")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("torneo_comisiones")
}

model ChecklistTemplate {
  id          String               @id @default(uuid())
  nombre      String
  descripcion String?              @db.Text
  esDefault   Boolean              @default(false) @map("es_default")
  activo      Boolean              @default(true)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  items ChecklistTemplateItem[]

  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id          String            @id @default(uuid())
  templateId  String            @map("template_id")
  categoria   String            // PELOTAS, AUSPICIANTES, PREMIOS, INFRAESTRUCTURA, BEBIDAS, LOGISTICA, OTRO
  titulo      String
  descripcion String?           @db.Text
  orden       Int               @default(0)
  esCalculado Boolean           @default(false) @map("es_calculado") // Si es cálculo automático (pelotas)
  formula     String?           // Fórmula para cálculo automático
  createdAt   DateTime          @default(now()) @map("created_at")

  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("checklist_template_items")
}

model ChecklistItem {
  id                String    @id @default(uuid())
  tournamentId      String    @map("tournament_id")
  templateItemId    String?   @map("template_item_id")
  categoria         String
  titulo            String
  descripcion       String?   @db.Text
  fechaRecordatorio DateTime? @map("fecha_recordatorio")
  recordatorioEnviado Boolean @default(false) @map("recordatorio_enviado")
  completado        Boolean   @default(false)
  completadoAt      DateTime? @map("completado_at")
  notas             String?   @db.Text
  valorCalculado    Int?      @map("valor_calculado") // Para pelotas: cantidad estimada
  valorReal         Int?      @map("valor_real") // Ajustado por organizador
  orden             Int       @default(0)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
}

model NotificacionEnviada {
  id             String   @id @default(uuid())
  tournamentId   String   @map("tournament_id")
  inscripcionId  String?  @map("inscripcion_id")
  tipo           String   // SMS, EMAIL, WHATSAPP
  destinatario   String   // phone o email
  template       String   // INVITACION_JUGADOR, RECORDATORIO_CHECKLIST, etc
  contenido      String   @db.Text
  estado         String   @default("ENVIADO") // ENVIADO, ENTREGADO, FALLIDO
  errorMsg       String?  @map("error_msg") @db.Text
  enviadoAt      DateTime @default(now()) @map("enviado_at")
  leido          Boolean  @default(false)
  leidoAt        DateTime? @map("leido_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId, tipo])
  @@map("notificaciones_enviadas")
}

// ═══════════════════════════════════════════════════════
// MÓDULO: DATOS DE PRUEBA / DEMO
// ═══════════════════════════════════════════════════════

model JugadorDemo {
  id          String   @id @default(uuid())
  nombre      String
  apellido    String
  documento   String   @unique
  email       String   @unique
  telefono    String
  genero      Gender
  categoriaId String   @map("categoria_id") // Categoría base del jugador
  
  // Si se convierte en usuario real, se vincula aquí
  userId      String?  @unique @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("jugadores_demo")
}
